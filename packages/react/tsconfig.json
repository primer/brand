{
  "compilerOptions": {
    "declaration": true,
    "target": "esnext",
    "module": "esnext",
    "lib": ["esnext", "dom", "dom.iterable"],
    "emitDeclarationOnly": false,
    "skipLibCheck": false,
    "sourceMap": true,
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "outDir": "lib",
    "jsx": "react-jsx",
    "plugins": [{"name": "typescript-plugin-css-modules"}],
    "resolveJsonModule": true,
    "types": ["node", "react", "react-dom", "chai"],
    "paths": {
      // Resolve vite from this package, not the hoisted root copy from Storybook
      "vite": ["./node_modules/vite"]
    }
  },
  "include": ["src/**/*", "scripts/**/*", "vite.esm.config.ts"],
  "exclude": ["integration-tests/**/*"]
}
