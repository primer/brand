#!/bin/bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../../.." && pwd)"

# Run all tests with npm run test:visual.
# Optionally: Run single stories 
# Examples:
#   npm run test:visual:update -- SubNav.visual.spec.ts
#   npm run test:visual:update -- --grep "Anchor Nav Variant"
SKIP_BUILD="${SKIP_BUILD:-0}"
SKIP_STORYBOOK_BUILD="${SKIP_STORYBOOK_BUILD:-0}"
SKIP_GENERATE="${SKIP_GENERATE:-0}"

cd "${REPO_ROOT}"
if [[ "${SKIP_BUILD}" != "1" ]]; then
  npm run build:lib
fi

if [[ "${SKIP_STORYBOOK_BUILD}" != "1" ]]; then
  cd "${REPO_ROOT}/apps/storybook"
  NODE_ENV=test npx storybook build
fi

cd "${REPO_ROOT}/packages/e2e"
if [[ "${SKIP_GENERATE}" != "1" ]]; then
  npx tsx scripts/playwright/playwright.generate-tests.ts
fi

PLAYWRIGHT_COMMAND=(npx playwright test --update-snapshots --max-failures 0)
if [[ $# -gt 0 ]]; then
  # Convenience: allow passing a plain test title string without --grep.
  if [[ "$1" != -* && "$1" != *.ts && "$1" != *.tsx ]]; then
    GREP_TERMS=()
    while [[ $# -gt 0 ]]; do
      if [[ "$1" == -* || "$1" == *.ts || "$1" == *.tsx ]]; then
        break
      fi

      GREP_TERMS+=("$1")
      shift
    done

    if [[ ${#GREP_TERMS[@]} -gt 0 ]]; then
      printf -v GREP_PATTERN '%s ' "${GREP_TERMS[@]}"
      GREP_PATTERN="${GREP_PATTERN% }"
      PLAYWRIGHT_COMMAND+=(--grep "$GREP_PATTERN")
    fi
  fi

  if [[ $# -gt 0 ]]; then
    PLAYWRIGHT_COMMAND+=("$@")
  fi
fi
printf -v PLAYWRIGHT_COMMAND_ESCAPED '%q ' "${PLAYWRIGHT_COMMAND[@]}"
npx start-server-and-test \
  "npx http-server ${REPO_ROOT}/apps/storybook/storybook-static -p 6006" \
  6006 \
  "cd ${REPO_ROOT}/packages/e2e && ${PLAYWRIGHT_COMMAND_ESCAPED}"
