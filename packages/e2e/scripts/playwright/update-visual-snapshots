#!/bin/bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../../.." && pwd)"

# Run all tests with npm run test:visual.
# Optionally: Run single stories
# Examples:
#   npm run test:visual:update -- SubNav.visual.spec.ts
#   npm run test:visual:update -- --grep "Anchor Nav Variant"
cd "${REPO_ROOT}"
npm run build:lib

cd "${REPO_ROOT}/apps/storybook"
NODE_ENV=test npx storybook build

cd "${REPO_ROOT}/packages/e2e"
if [[ -z "${PLAYWRIGHT_CHROME_PATH:-}" ]]; then
  echo "Installing Playwright Chrome browser..."
  npx playwright install chrome
fi

npx tsx scripts/playwright/playwright.generate-tests.ts

PLAYWRIGHT_COMMAND=(npx playwright test --update-snapshots --max-failures 0 "$@")
printf -v PLAYWRIGHT_COMMAND_ESCAPED '%q ' "${PLAYWRIGHT_COMMAND[@]}"
npx start-server-and-test \
  "npx http-server \"${REPO_ROOT}/apps/storybook/storybook-static\" -p 6006" \
  6006 \
  "cd \"${REPO_ROOT}/packages/e2e\" && ${PLAYWRIGHT_COMMAND_ESCAPED}"
